# ── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
PUBLIC_URL=https://clipseller.com.br

# ── Postgres ──────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=clipseller
DB_USER=clipseller
DB_PASSWORD=changeme

# ── JWT ───────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 48
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=24h

# ── AWS SES (envio de e-mails: boas-vindas, esqueci minha senha) ──────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MAIL_FROM=no-reply@selleriaclub.com.br
MAIL_FROM_NAME=ClipSeller
SES_CONFIGURATION_SET=
MAIL_DRY_RUN=false

# Créditos de boas-vindas ao criar conta (Hotmart ou admin)
WELCOME_CREDITS=50

# ── Mercado Pago (compra de créditos avulsos/pacotes) ─────────────────────
MP_ACCESS_TOKEN=
MP_SANDBOX=true
MP_WEBHOOK_SECRET=

# ── Admin bootstrap (criado/atualizado no boot) ───────────────────────────
ADMIN_EMAIL=acesso@selleriaclub.com
ADMIN_PASSWORD=changeme-on-first-login
ADMIN_NAME=Admin ClipSeller


# ── Hotmart (produto standalone ClipSeller) ───────────────────────────────
HOTMART_CLIPSELLER_PRODUCT_IDS=7932619
# Configure quando criar o webhook na Hotmart. Vazio = validação desativada.
HOTMART_WEBHOOK_HOTTOK=

# ── Chaves de IA (server-side via /cs-proxy — nunca expor no cliente) ─────
# Deixe em branco o que não for usar. Os nomes abaixo batem com src/proxy/routes.js.
ANTHROPIC_API_KEY=
FAL_API_KEY=
REPLICATE_API_KEY=
FREEPIK_API_KEY=
GEMINI_API_KEY=
FASHN_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
LAOZHANG_API_KEY=
LAOZHANG_IMAGE_API_KEY=
LAOZHANG_SORA_API_KEY=
KIE_API_KEY=
EVOLINK_API_KEY=
PIAPI_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
